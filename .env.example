# Copy to .env and fill in. Never commit .env.

# --- Server ---
PORT=8000
ENV=development
CORS_ORIGIN=*

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_MINUTES=1440

# --- Database (PostgreSQL via SQLAlchemy) ---
# Either a full SQLAlchemy URL...
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/routecare
# ...or individual PG* vars (used when DATABASE_URL is empty):
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=routecare

# --- OTP / SMS ---
# "console" prints codes to the server log in development.
OTP_PROVIDER=console
